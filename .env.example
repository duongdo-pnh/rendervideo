# Copy this file to `.env` and fill in your keys. Loaded automatically by latentsync/tts/factory.py.

# ---- TTS default provider (vbee / ausynclab / api / local) ----
DEFAULT_TTS_PROVIDER=vbee

# ---- Vbee AI Voice (async: POST job -> poll -> download mp3). Cần CẢ App ID + Access Token ----
VBEE_APP_ID=                                   # UUID, vd ff6f220b-dd63-44fb-b233-e045fde8a2ef
VBEE_TOKEN=                                    # Access Token (JWT) — bí mật, KHÔNG commit
VBEE_DEFAULT_VOICE=hn_female_ngochuyen_full_48k-fhg
VBEE_WEBHOOK_URL=https://example.com/vbee-callback   # bắt buộc bởi API (ta poll, không dùng webhook)
# VBEE_SPEED=1.0
# VBEE_TIMEOUT=60                               # giây, chờ poll job xong
# VBEE_OUTPUT_FORMAT=mp3
# VBEE_API_URL=https://api.vbee.vn/v1/tts       # override nếu cần
# VBEE_STATUS_URL=https://api.vbee.vn/v1/tts/requests
# VBEE_VOICES_URL=https://vbee.vn/api/public/v1/voices

# ---- Audiosynclab (AusyncLab) — auth header X-API-Key, async create -> poll -> download ----
AUSYNCLAB_API_KEY=                             # ak_xxxxxxxx (Master hoặc Sub key)
AUSYNCLAB_DEFAULT_VOICE=                        # voice_id (lấy từ nút "Kết nối & tải giọng")
AUSYNCLAB_API_URL=https://api.ausynclab.io/api/v1
# AUSYNCLAB_LANGUAGE=vi
# AUSYNCLAB_MODEL=                              # model_name nếu tài khoản yêu cầu
# AUSYNCLAB_SPEED=1.0
# AUSYNCLAB_TIMEOUT=60
# --- override path khi có doc TTS chính thức ---
# AUSYNCLAB_TTS_PATH=/speech/text-to-speech
# AUSYNCLAB_GET_PATH=/speech/{id}
# AUSYNCLAB_VOICES_PATH=/voices

# ---- Generic online API (OpenAI TTS / ElevenLabs) ----
TTS_API_KEY=
TTS_API_URL=https://api.openai.com/v1/audio/speech
TTS_API_TYPE=openai           # openai / elevenlabs
TTS_API_DEFAULT_VOICE=alloy
# TTS_API_MODEL=tts-1

# ---- Local offline TTS (Piper / Coqui) ----
LOCAL_TTS_ENGINE=piper        # piper / coqui
LOCAL_TTS_MODEL_PATH=models/tts/vi_VN
LOCAL_TTS_DEFAULT_VOICE=vi_VN-thuy-medium
